# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# Leave unset to disable analytics — the layout will not render the gtag script.
NEXT_PUBLIC_GA_ID=

# Google AdSense publisher ID (e.g. ca-pub-1234567890123456)
# Leave unset to disable ads — no ad script or slots will render until this is set.
NEXT_PUBLIC_ADSENSE_ID=
